{
  "name": "fleet-safety-telemetry-console",
  "version": "0.1.0",
  "description": "Automotive and robotics fleet safety telemetry console for sensor drift, override events, mission exceptions, and board-ready readiness posture.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizcausevic-dev/fleet-safety-telemetry-console.git"
  },
  "keywords": ["automotive", "robotics", "fleet-safety", "telemetry", "c-plus-plus", "rust", "python", "kinetic-gain"],
  "bin": { "fleet-safety-telemetry-console": "dist/cli.js" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx scripts/run_demo.ts",
    "prerender": "tsx scripts/prerender.ts",
    "smoke": "tsx scripts/smoke_check.ts",
    "cpp:test": "tsx scripts/run_cpp_check.ts",
    "rust:test": "cargo test --manifest-path crates/fleet-normalizer/Cargo.toml",
    "python:test": "python -m unittest discover -s python/tests",
    "python:demo": "python python/fleet_safety_console/pack.py fixtures/fleet-telemetry.json --format markdown",
    "verify": "npm run lint && npm run typecheck && npm run coverage && npm run build && npm run demo && npm run python:test && npm run prerender && npm run smoke && npm run cpp:test && npm run rust:test",
    "render:assets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\render_readme_assets.ps1"
  },
  "dependencies": { "express": "^5.2.1" },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.17.0",
    "globals": "^16.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.8"
  },
  "engines": { "node": ">=20" }
}
